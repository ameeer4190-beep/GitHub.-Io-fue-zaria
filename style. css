:root {
  --green: #006633;
  --green-dark: #004d26;
  --green-light: #00994d;
  --gold: #c8a84b;
  --white: #ffffff;
  --off-white: #f7f9f5;
  --text: #1a1a1a;
  --muted: #6b7280;
  --border: #e5e7eb;
  --shadow: 0 4px 24px rgba(0,102,51,0.10);
  --radius: 14px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--off-white);
  color: var(--text);
  min-height: 100vh;
}

/* NAV */
#navbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(0,102,51,0.97);
  backdrop-filter: blur(12px);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 40px;
  height: 64px;
  box-shadow: 0 2px 20px rgba(0,0,0,0.15);
}
.nav-brand { display: flex; align-items: center; gap: 12px; }
.logo-circle {
  width: 40px; height: 40px; border-radius: 50%;
  background: var(--gold);
  color: var(--green-dark);
  font-family: 'Playfair Display', serif;
  font-weight: 900; font-size: 13px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.logo-circle.small { width: 32px; height: 32px; font-size: 11px; }
.brand-name { display: block; color: #fff; font-weight: 700; font-size: 16px; line-height: 1; }
.brand-sub { display: block; color: rgba(255,255,255,0.6); font-size: 11px; }
.nav-links { display: flex; align-items: center; gap: 28px; }
.nav-links a { color: rgba(255,255,255,0.85); text-decoration: none; font-size: 14px; font-weight: 500; transition: color .2s; }
.nav-links a:hover { color: var(--gold); }
.btn-admin {
  background: var(--gold); color: var(--green-dark);
  border: none; border-radius: 8px;
  padding: 8px 18px; font-size: 13px; font-weight: 700;
  cursor: pointer; transition: opacity .2s;
}
.btn-admin:hover { opacity: 0.85; }
.hamburger { display: none; color: #fff; font-size: 22px; cursor: pointer; }

/* HERO */
.hero {
  min-height: 100vh;
  background: linear-gradient(135deg, var(--green-dark) 0%, var(--green) 60%, var(--green-light) 100%);
  display: flex; align-items: center; justify-content: space-between;
  padding: 100px 60px 60px;
  position: relative; overflow: hidden;
  gap: 40px;
}
.hero-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 70% 50%, rgba(200,168,75,0.12) 0%, transparent 60%),
              url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  pointer-events: none;
}
.hero-content { max-width: 540px; position: relative; z-index: 1; }
.hero-badge {
  display: inline-block;
  background: rgba(200,168,75,0.2); color: var(--gold);
  border: 1px solid rgba(200,168,75,0.4);
  border-radius: 100px; padding: 6px 16px;
  font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
  margin-bottom: 20px;
}
.hero-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(36px, 5vw, 62px);
  color: #fff; line-height: 1.1;
  margin-bottom: 20px;
}
.hero-title span { color: var(--gold); }
.hero-desc { color: rgba(255,255,255,0.75); font-size: 16px; line-height: 1.7; margin-bottom: 32px; }
.hero-btns { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 48px; }
.btn-primary {
  background: var(--gold); color: var(--green-dark);
  border: none; border-radius: 10px;
  padding: 13px 28px; font-size: 14px; font-weight: 700;
  cursor: pointer; text-decoration: none; display: inline-block;
  transition: transform .2s, box-shadow .2s;
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(200,168,75,0.4); }
.btn-primary.full { width: 100%; text-align: center; margin-top: 12px; }
.btn-outline {
  background: transparent; color: #fff;
  border: 1.5px solid rgba(255,255,255,0.5);
  border-radius: 10px; padding: 13px 28px;
  font-size: 14px; font-weight: 600;
  text-decoration: none; display: inline-block;
  transition: border-color .2s, background .2s;
}
.btn-outline:hover { border-color: var(--gold); background: rgba(200,168,75,0.1); }
.hero-stats { display: flex; gap: 40px; }
.stat { display: flex; flex-direction: column; }
.stat strong { color: var(--gold); font-size: 28px; font-weight: 700; font-family: 'Playfair Display', serif; }
.stat span { color: rgba(255,255,255,0.6); font-size: 13px; }

/* Photo Stack */
.hero-visual { position: relative; flex-shrink: 0; width: 360px; height: 380px; }
.photo-stack { position: relative; width: 100%; height: 100%; }
.stack-card {
  position: absolute; border-radius: 18px;
  overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.3);
}
.s1 { width: 240px; height: 300px; top: 40px; right: 0; transform: rotate(3deg); z-index: 3; }
.s2 { width: 220px; height: 280px; top: 20px; right: 60px; transform: rotate(-4deg); z-index: 2; }
.s3 { width: 200px; height: 260px; top: 60px; right: 100px; transform: rotate(1deg); z-index: 1; }
.card-img { width: 100%; height: 100%; }
.cs-bg { background: linear-gradient(180deg, #1a4a2e 0%, #2d7a4f 50%, #006633 100%); display: flex; align-items: center; justify-content: center; font-size: 80px; }
.cs-bg2 { background: linear-gradient(180deg, #004d26 0%, #006633 100%); display: flex; align-items: center; justify-content: center; font-size: 80px; }
.cs-bg3 { background: linear-gradient(180deg, #00994d 0%, #006633 100%); display: flex; align-items: center; justify-content: center; font-size: 80px; }
.cs-bg::after { content: '🎓'; }
.cs-bg2::after { content: '📸'; }
.cs-bg3::after { content: '🏛️'; }

/* SECTIONS */
.departments, .gallery-section { padding: 80px 60px; }
.section-header { text-align: center; margin-bottom: 48px; }
.section-label { color: var(--green); font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 10px; }
.section-header h2 { font-family: 'Playfair Display', serif; font-size: 40px; color: var(--text); }

/* DEPT GRID */
.dept-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; max-width: 900px; margin: 0 auto; }
.dept-card {
  background: #fff; border-radius: var(--radius);
  padding: 28px 20px; text-align: center;
  border: 2px solid var(--border);
  cursor: pointer; transition: all .25s; position: relative;
}
.dept-card:hover { border-color: var(--green); transform: translateY(-4px); box-shadow: var(--shadow); }
.dept-card.active { border-color: var(--green); background: linear-gradient(135deg, #f0fff7, #fff); }
.dept-card.coming { opacity: 0.55; cursor: default; }
.dept-card.coming:hover { transform: none; box-shadow: none; border-color: var(--border); }
.dept-icon { font-size: 32px; margin-bottom: 12px; }
.dept-card h3 { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
.dept-card p { font-size: 13px; color: var(--muted); }
.dept-badge {
  position: absolute; top: 10px; right: 10px;
  background: var(--green); color: #fff;
  font-size: 10px; font-weight: 700; letter-spacing: 1px;
  padding: 3px 8px; border-radius: 100px; text-transform: uppercase;
}

/* GALLERY CONTROLS */
.gallery-controls { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 20px; }
.gallery-controls input, .gallery-controls select {
  border: 1.5px solid var(--border); border-radius: 8px;
  padding: 10px 16px; font-size: 14px; background: #fff;
  outline: none; transition: border-color .2s;
}
.gallery-controls input:focus, .gallery-controls select:focus { border-color: var(--green); }
.gallery-controls input { min-width: 220px; }

/* GALLERY GRID */
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 20px;
  max-width: 1200px; margin: 0 auto;
}
.photo-card {
  background: #fff; border-radius: var(--radius);
  overflow: hidden; box-shadow: var(--shadow);
  transition: transform .25s, box-shadow .25s;
  cursor: pointer; position: relative;
}
.photo-card:hover { transform: translateY(-6px); box-shadow: 0 12px 40px rgba(0,102,51,0.15); }
.photo-card-img {
  width: 100%; aspect-ratio: 4/5;
  object-fit: cover;
  display: flex; align-items: center; justify-content: center;
  font-size: 60px;
}
.photo-card-body { padding: 14px 16px; }
.photo-card-name { font-weight: 700; font-size: 15px; margin-bottom: 4px; }
.photo-card-dept { font-size: 12px; color: var(--muted); margin-bottom: 10px; }
.photo-card-actions { display: flex; gap: 10px; }
.action-btn {
  flex: 1; border: 1.5px solid var(--border);
  background: none; border-radius: 8px;
  padding: 7px 4px; font-size: 12px; font-weight: 600;
  cursor: pointer; transition: all .2s;
  display: flex; align-items: center; justify-content: center; gap: 4px;
}
.action-btn:hover { border-color: var(--green); color: var(--green); }
.action-btn.liked { border-color: #e11d48; color: #e11d48; background: #fff1f3; }
.admin-badge {
  position: absolute; top: 10px; right: 10px;
  background: rgba(0,0,0,0.6); color: #fff;
  font-size: 10px; padding: 3px 8px; border-radius: 100px;
  display: none;
}

/* OVERLAYS */
.overlay {
  position: fixed; inset: 0; z-index: 200;
  background: rgba(0,0,0,0.6);
  display: flex; align-items: center; justify-content: center;
  padding: 20px;
  backdrop-filter: blur(4px);
}
.overlay.hidden { display: none; }
.close-btn {
  position: absolute; top: 16px; right: 16px;
  background: rgba(0,0,0,0.08); border: none;
  width: 32px; height: 32px; border-radius: 50%;
  font-size: 16px; cursor: pointer; z-index: 10;
  display: flex; align-items: center; justify-content: center;
}

/* ADMIN PANEL */
.admin-panel {
  background: #fff; border-radius: 20px;
  width: 100%; max-width: 620px;
  max-height: 90vh; overflow-y: auto;
  padding: 40px; position: relative;
}
.admin-section h2 { font-family: 'Playfair Display', serif; font-size: 28px; margin-bottom: 4px; }
.admin-section p { color: var(--muted); margin-bottom: 24px; font-size: 14px; }
.admin-section input, .admin-section textarea, .admin-section select {
  width: 100%; border: 1.5px solid var(--border);
  border-radius: 10px; padding: 12px 16px;
  font-size: 14px; margin-bottom: 12px; outline: none;
  font-family: 'DM Sans', sans-serif;
  transition: border-color .2s;
}
.admin-section input:focus, .admin-section textarea:focus { border-color: var(--green); }
.login-hint { font-size: 12px; color: var(--muted); text-align: center; margin-top: 8px; }
.hidden { display: none !important; }

/* ADMIN TABS */
.admin-tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px; border-bottom: 2px solid var(--border); padding-bottom: 12px; }
.tab-btn {
  background: none; border: none; padding: 8px 16px;
  font-size: 13px; font-weight: 600; cursor: pointer;
  border-radius: 8px; color: var(--muted); transition: all .2s;
}
.tab-btn.active { background: var(--green); color: #fff; }
.tab-content { animation: fadeIn .25s; }

/* UPLOAD ZONE */
.upload-zone {
  border: 2px dashed var(--green); border-radius: 12px;
  padding: 40px; text-align: center;
  cursor: pointer; transition: background .2s; margin-bottom: 16px;
}
.upload-zone:hover { background: #f0fff7; }
.upload-icon { font-size: 36px; }
.upload-zone p { font-weight: 600; margin: 8px 0 4px; }
.upload-zone span { font-size: 12px; color: var(--muted); }
.upload-preview { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 12px; }
.upload-preview img { width: 70px; height: 70px; object-fit: cover; border-radius: 8px; }
.upload-meta label { font-size: 13px; font-weight: 600; display: block; margin-bottom: 4px; color: var(--text); }

/* ADMIN TABLE */
.admin-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.admin-table th { background: var(--off-white); padding: 10px 12px; text-align: left; font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: .5px; }
.admin-table td { padding: 10px 12px; border-bottom: 1px solid var(--border); }

/* ADMIN GALLERY LIST */
.admin-gallery-list { display: flex; flex-direction: column; gap: 10px; }
.admin-photo-row {
  display: flex; align-items: center; gap: 12px;
  background: var(--off-white); border-radius: 10px; padding: 10px;
}
.admin-photo-row img { width: 50px; height: 50px; object-fit: cover; border-radius: 8px; }
.admin-photo-row .aph-info { flex: 1; }
.admin-photo-row .aph-name { font-weight: 700; font-size: 14px; }
.admin-photo-row .aph-stats { font-size: 12px; color: var(--muted); }
.delete-btn {
  background: #fee2e2; color: #dc2626; border: none;
  border-radius: 8px; padding: 6px 12px;
  font-size: 12px; font-weight: 700; cursor: pointer;
}

/* LIGHTBOX */
.lightbox-inner {
  background: #fff; border-radius: 20px;
  width: 100%; max-width: 700px;
  max-height: 90vh; overflow-y: auto;
  padding: 32px; position: relative;
}
.lightbox-inner img { width: 100%; border-radius: 12px; max-height: 400px; object-fit: cover; margin-bottom: 16px; }
.lb-info { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; flex-wrap: wrap; margin-bottom: 20px; }
.lb-info h3 { font-family: 'Playfair Display', serif; font-size: 22px; }
.lb-info p { color: var(--muted); font-size: 13px; }
.lb-actions { display: flex; gap: 10px; flex-wrap: wrap; }
.lb-btn {
  border: 1.5px solid var(--border); background: #fff;
  border-radius: 8px; padding: 8px 16px;
  font-size: 13px; font-weight: 600; cursor: pointer;
  transition: all .2s; white-space: nowrap;
}
.lb-btn:hover { border-color: var(--green); color: var(--green); }
.lb-btn.like-btn.liked { border-color: #e11d48; color: #e11d48; background: #fff1f3; }

/* COMMENTS */
.comments-section h4 { font-size: 15px; font-weight: 700; margin-bottom: 12px; }
.comments-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; max-height: 200px; overflow-y: auto; }
.comment {
  background: var(--off-white); border-radius: 10px; padding: 10px 14px;
}
.comment-author { font-weight: 700; font-size: 13px; margin-bottom: 3px; }
.comment-text { font-size: 13px; color: var(--muted); }
.comment-time { font-size: 11px; color: #9ca3af; margin-top: 3px; }
.comment-input { display: flex; gap: 8px; flex-wrap: wrap; }
.comment-input input { flex: 1; min-width: 120px; border: 1.5px solid var(--border); border-radius: 8px; padding: 10px 14px; font-size: 13px; outline: none; }
.comment-input input:focus { border-color: var(--green); }
.comment-input button { padding: 10px 20px; font-size: 13px; }

/* TOAST */
.toast {
  position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%);
  background: var(--green-dark); color: #fff;
  border-radius: 10px; padding: 12px 24px;
  font-size: 14px; font-weight: 500; z-index: 999;
  animation: slideUp .3s;
}
.toast.hidden { display: none; }

/* FOOTER */
.footer { background: var(--green-dark); color: #fff; padding: 40px 60px; }
.footer-inner { max-width: 1200px; margin: 0 auto; }
.footer-brand { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
.footer-brand strong { display: block; font-size: 16px; }
.footer-brand p { font-size: 13px; color: rgba(255,255,255,0.6); }
.footer-links { display: flex; gap: 24px; margin-bottom: 20px; }
.footer-links a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; transition: color .2s; }
.footer-links a:hover { color: var(--gold); }
.footer-credit { font-size: 13px; color: rgba(255,255,255,0.5); }

/* ANIMATIONS */
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
@keyframes slideUp { from { opacity: 0; transform: translate(-50%, 20px); } to { opacity: 1; transform: translate(-50%, 0); } }

/* RESPONSIVE */
@media (max-width: 900px) {
  .hero { flex-direction: column; padding: 100px 30px 60px; text-align: center; }
  .hero-btns { justify-content: center; }
  .hero-stats { justify-content: center; }
  .hero-visual { display: none; }
  .departments, .gallery-section { padding: 60px 24px; }
  .nav-links { display: none; }
  .hamburger { display: block; }
  .admin-panel { padding: 24px; }
  .footer { padding: 40px 24px; }
  #navbar { padding: 0 20px; }
}
@media (max-width: 500px) {
  .gallery-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
  .dept-grid { grid-template-columns: 1fr 1fr; }
}
